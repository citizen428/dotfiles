# Optional extra gems
%w[active_support/all amazing_print methodfinder].each do |gem|
  require gem rescue nil
end

if defined?(AmazingPrint) && ENV["SKIP_AP"] != "true"
  AmazingPrint.irb!
  AmazingPrint.defaults = {
    indent: 2,
    ruby19_syntax: true,
    sort_keys: true,
    sort_vars: true,
  }
else
  # Make sure we always have an 'ap' command available
  alias ap pp
end

# Monkey-patches
class Object
  def d
    tap { |s| puts s }
  end

  def im
    if self.class == Module
      (singleton_methods + instance_methods).uniq.sort
    else
      (public_methods - Object.methods).sort
    end
  end

  def self.im
    (public_methods - Object.methods).sort
  end
end
