[alias]
  # http://gitready.com/intermediate/2009/02/12/easily-fetching-upstream-changes.html
  pu                  = !"git fetch origin -v; git fetch upstream -v; git merge upstream/master"
  # update submodules
  subup               = !"git pull --recurse-submodules && git submodule update"
  # reset rails schema.db to commit we branched off
  schemareset         = !sh -c 'git checkout $(git merge-base ${1:-development} $(git symbolic-ref HEAD)) -- db/schema.rb' -
  sqlreset            = !sh -c 'git checkout $(git merge-base ${1:-development} $(git symbolic-ref HEAD)) -- db/structure.sql' -
  # delete branches that have already been merged into the current branch
  rmmerged            = !"git branch --merged | grep -v '*' | grep -v \"master\" | xargs -n 1 git branch -d && git remote prune origin"
  count               = shortlog -sn
  changedfiles        = !sh -c 'git diff --name-only HEAD $(git merge-base HEAD master)' -
  change-commits      = "!f() { VAR=$1; OLD=$2; NEW=$3; shift 3; git filter-branch --env-filter \"if [[ \\\"$`echo $VAR`\\\" = '$OLD' ]]; then export $VAR='$NEW'; fi\" $@; }; f "

  #  Mostly from http://www.metacircus.com/hacking/2011/02/18/play-git-like-a-violin.html
  # I like using the interactive mode to make complex commits
  a                   = add --all
  ai                  = add --interactive

  # All the aliases relate to commits. Note that
  # they are grouped by common prefixes, so I don't
  # confuse what I want done by accident.
  c                   = commit
  # commit with a message
  cm                  = commit -m
  cma                 = commit -a -m
  # amending the previous commit
  ca                  = commit --amend
  caa                 = commit -a --amend -C HEAD

  deleted             = log --diff-filter=D --summary

  # reset
  ## soft resets
  r                   = reset
  r1                  = reset HEAD^
  r2                  = reset HEAD^^
  ## hard resets
  rh                  = reset --hard
  rh1                 = reset HEAD^ --hard
  rh1                 = reset HEAD^^ --hard

  # shortcuts for commands
  b                   = branch
  co                  = checkout
  d                   = diff
  f                   = fetch
  l                   = log
  lg                  = log --graph --oneline --decorate --date=relative --all
  m                   = merge
  mt                  = mergetool
  p                   = pull
  rp                  = git remote prune origin
  s                   = status -sb
  st                  = status
  conflicts           = diff --name-only --diff-filter=U
[core]
  excludesfile        = ~/.gitignore
  editor              = vim
  autocrlf            = input
[push]
  default             = current
[merge]
  tool                = diffmerge
  stat                = true
[rerere]
  enabled             = true
[pull]
  rebase              = true
[filter "lfs"]
  clean               = git-lfs clean -- %f
  smudge              = git-lfs smudge -- %f
  required            = true
  process             = git-lfs filter-process
[credential]
  helper              = osxkeychain
[rebase]
  autosquash          = true
[difftool]
  prompt = false
  trustExitCode = true
[hub]
  protocol            = ssh
[core]
  pager = delta --plus-color="#012800" --minus-color="#340001"
[interactive]
  diffFilter = delta --color-only
